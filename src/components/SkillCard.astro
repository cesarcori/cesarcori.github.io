---
import { SKILLS } from "../data/portfolioData";
---

<div
    class="max-w-4xl mx-auto bg-grey-100 text-slate-800 rounded-2xl shadow-lg overflow-hidden border border-slate-200"
>
    <div class="p-8">
        <!-- <div class="flex items-center justify-between mb-6">
            <h2 class="text-2xl font-bold tracking-tight">Technical Stack</h2>
            <span
                class="px-3 py-1 bg-purple-500/20 text-purple-400 text-xs font-bold uppercase rounded-full border border-purple-500/30"
            >
                3+ Years Exp
            </span>
        </div> -->

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Frontend Section -->
            <div class="space-y-3">
                <h3
                    class="text-sm font-semibold text-slate-500 uppercase tracking-wider"
                >
                    Frontend
                </h3>
                <div class="flex flex-wrap gap-2">
                    {
                        SKILLS.frontend.map((skill) => (
                            <span class="px-3 py-1 bg-cyan-500/10 text-cyan-600 rounded-md border border-cyan-600/20 text-sm font-medium">
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>

            <!-- Backend Section -->
            <div class="space-y-3">
                <h3
                    class="text-sm font-semibold text-slate-500 uppercase tracking-wider"
                >
                    Backend
                </h3>
                <div class="flex flex-wrap gap-2">
                    {
                        SKILLS.backend.map((skill) => (
                            <span class="px-3 py-1 bg-cyan-500/10 text-cyan-600 rounded-md border border-cyan-600/20 text-sm font-medium">
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>

            <!-- DevOps/Tools Section -->
            <div class="space-y-3 md:col-span-2">
                <h3
                    class="text-sm font-semibold text-slate-500 uppercase tracking-wider"
                >
                    Infrastructure & Environment
                </h3>
                <div class="flex flex-wrap gap-2">
                    {
                        SKILLS.infrastructure.map((skill) => (
                            <span class="px-3 py-1 bg-cyan-500/10 text-cyan-600 rounded-md border border-cyan-600/20 text-sm font-medium">
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</div>
